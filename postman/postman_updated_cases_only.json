{
  "info": {
    "_postman_id": "f1df035a-9955-40a4-9c94-6ab70670b154",
    "name": "POS Warehouse - Updated Cases Only",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Only test cases for recently updated behaviors: JWT-based createdBy, oversell blocking, and cross-parent validation. Uses environment variables style from your existing collection."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:6591/api" },
    { "key": "token", "value": "" },
    { "key": "warehouseId", "value": "1" },
    { "key": "supplierSeedId", "value": "" },
    { "key": "customerSeedId", "value": "" },
    { "key": "productId", "value": "1" },
    { "key": "lowStockProductId", "value": "1" },
    { "key": "salePrice", "value": "10000" },
    { "key": "targetPoId", "value": "10" },
    { "key": "poItemIdFromOtherPo", "value": "8" },
    { "key": "grProductId", "value": "1" }
  ],
  "item": [
    {
      "name": "01 - Auth (reuse env style)",
      "item": [
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login success', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token || '');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - JWT createdBy (no createdByStaffId in body)",
      "item": [
        {
          "name": "PO Create Draft - no createdByStaffId",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/purchase-orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supplierId\": \"{{supplierSeedId}}\",\n  \"expectedDate\": \"2026-12-31\",\n  \"note\": \"PO create by JWT\",\n  \"warehouseId\": {{warehouseId}},\n  \"items\": [\n    {\n      \"productId\": {{productId}},\n      \"orderedQty\": 1,\n      \"expectedUnitCost\": 100000\n    }\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Expect success (2xx)', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 - Oversell Protection (Order)",
      "item": [
        {
          "name": "Create Order - quantity > on_hand should be blocked",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"warehouseId\": {{warehouseId}},\n  \"paymentMethod\": \"CASH\",\n  \"discountAmount\": 0,\n  \"surchargeAmount\": 0,\n  \"items\": [\n    {\n      \"productId\": {{lowStockProductId}},\n      \"quantity\": 999999,\n      \"salePrice\": {{salePrice}}\n    }\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Expect blocked (4xx)', function () { pm.expect(pm.response.code).to.be.oneOf([400, 401, 403, 409, 422]); });",
                  "let json = {}; try { json = pm.response.json(); } catch (e) {}",
                  "pm.test('Has error message', function () { pm.expect((json.message || '')).to.not.eql(''); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04 - Cross-Parent Validation (Goods Receipt)",
      "item": [
        {
          "name": "Create GR - poItemId from different PO should be blocked",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/goods-receipts",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"poId\": {{targetPoId}},\n  \"supplierId\": \"{{supplierSeedId}}\",\n  \"warehouseId\": {{warehouseId}},\n  \"note\": \"cross-parent mismatch test\",\n  \"items\": [\n    {\n      \"poItemId\": {{poItemIdFromOtherPo}},\n      \"productId\": {{grProductId}},\n      \"receivedQty\": 1,\n      \"unitCost\": 1000\n    }\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Expect blocked (4xx)', function () { pm.expect(pm.response.code).to.be.oneOf([400, 401, 403, 409, 422]); });",
                  "let json = {}; try { json = pm.response.json(); } catch (e) {}",
                  "pm.test('Has error message', function () { pm.expect((json.message || '')).to.not.eql(''); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
